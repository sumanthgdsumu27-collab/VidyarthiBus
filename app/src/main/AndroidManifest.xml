<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="VidyarthiBus"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VidyarthiBus">
        <activity android:name=".ProfileActivity" />
        <activity android:name=".RegisterActivity" />
        <!-- 1) LOGIN SCREEN (LAUNCHER / FIRST SCREEN) -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 2) ROLE SELECTION SCREEN -->
        <activity android:name=".RoleSelectionActivity" />

        <!-- 3) OTHER SCREENS -->
        <activity android:name=".MainActivity" />
        <activity android:name=".ReportBusListActivity" />
        <activity android:name=".ViewBusListActivity" />
        <activity android:name=".StudentActivity" />
        <activity android:name=".BusActivity" />

    </application>

</manifest>